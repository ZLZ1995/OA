# Zeabur 部署推荐环境变量（复制为平台环境变量即可）
APP_PORT=8080

# 默认单容器 SQLite；如果切换 PostgreSQL，请替换为实际连接串
DATABASE_URL=sqlite:////data/app.db

# 建议生产开启，确保启动时完成表结构和基础数据初始化
DB_INIT_REQUIRED=true

# 鉴权配置（务必替换为强随机值）
JWT_SECRET_KEY=replace-with-a-strong-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# 首次启动管理员账号（建议首登后修改密码）
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-me-in-production
INITIAL_ADMIN_REAL_NAME=系统管理员
